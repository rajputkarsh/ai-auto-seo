# LLM — when set, the API uses the model-backed reasoner (better titles/descriptions);
# when empty, the deterministic reasoner is used. Not required for tests or the eval.
ANTHROPIC_API_KEY=
# Per-scan spend ceiling for the LLM cost governor, in cents. Default 25.
LLM_BUDGET_CENTS=

# Infra (later phases)
DATABASE_URL=postgresql://localhost:5432/awe
REDIS_URL=redis://localhost:6379

# API
PORT=3000
RATE_LIMIT_MAX=60

# REQUIRED in any deployed environment — derives property verification tokens.
# Leaving the default lets anyone derive another property's token.
VERIFICATION_SECRET=
