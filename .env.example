# LLM (used by the future LLM-backed reasoner; NOT required for the deterministic MVP path)
ANTHROPIC_API_KEY=

# Infra (later phases)
DATABASE_URL=postgresql://localhost:5432/awe
REDIS_URL=redis://localhost:6379

# API
PORT=3000
RATE_LIMIT_MAX=60

# REQUIRED in any deployed environment — derives property verification tokens.
# Leaving the default lets anyone derive another property's token.
VERIFICATION_SECRET=
